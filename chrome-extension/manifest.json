        "utils/web/check-dom/modules/is-type-three.js",
        "utils/web/check-dom/modules/is-valid-elm.js",
        "utils/web/manip-data/index.js",
        "utils/web/manip-data/modules/highlight-terms.js",
        "utils/web/manip-dom/index.js",
        "utils/web/manip-dom/modules/adjust-element-size.js",
        "utils/web/manip-dom/modules/appender.js",
        "utils/web/manip-dom/modules/create-and-append-checkbox-to.js",
        "utils/web/manip-dom/modules/create-and-append-dt-dd-to.js",
        "utils/web/manip-dom/modules/create-and-append-li-to.js",
        "utils/web/manip-dom/modules/drag-element.js",
        "utils/web/manip-dom/modules/extend-text-area-by-value-length.js",
        "utils/web/manip-dom/modules/get-elm.js",
        "utils/web/manip-dom/modules/inline-styler.js",
        "utils/web/manip-dom/modules/insert-text-node-within.js",
        "utils/web/manip-dom/modules/keep-container-in-boundary.js",
        "utils/web/manip-dom/modules/remove-parent-keep-children-by.js",
        "utils/web/manip-dom/modules/set-container-dimensions-in-window.js",
        "utils/web/manip-dom/modules/set-css.js",
        "utils/web/manip-dom/modules/set-elm.js",
        "utils/web/manip-dom/modules/style-to-highlighted.js",
        "utils/web/manip-dom/modules/top-zindexer.js",
        "utils/web/manip-dom/modules/update-active-index.js",
        "utils/web/manip-keyboard/index.js",
        "utils/web/manip-keyboard/modules/go-to-next-term.js",
        "utils/web/manip-keyboard/modules/input-key-up.js",
        "utils/web/page-monitoring/index.js",
        "utils/web/page-monitoring/modules/delay.js",
        "utils/web/page-monitoring/modules/page-observer.js",
        "node_modules/socketcluster-client/socketcluster-client.min.js",
        "importer/index.js",
        "importer/importer.js",
        "scraper/index.js",
        "scraper/scraper.js"
      ]
    }
  ]
}
