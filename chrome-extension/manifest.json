{
  "manifest_version": 3,
  "name": "CrawlKeep",
  "version": "0.2.0.0",
  "description": "Upload a JSON file from your local directory to: \n - View its content in browser \n - Save and apply search criteria \n - Characterise the record  \n - Download your selection as a JSON file",
  "permissions": ["tabs", "storage", "unlimitedStorage", "scripting", "cookies", "webRequest"],
  "host_permissions": [
    "https://au.saasufy.com/*",
    "https://saasufy.com/*",
    "https://www.crawlkeep.com/*",
    "https://www.linkedin.com/*",
    "http://localhost:8081/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*", "https://linkedin.com/*"],
      "js": ["scraper/index.js"]
    },
    {
      "matches": ["https://www.crawlkeep.com/*", "https://crawlkeep.com/*", "http://localhost:8081/app/*"],
      "js": ["importer/index.js", "content-script.js"]
    }
  ],
  "icons": {
    "16": "images/icon-file-upload-white-64.png",
    "32": "images/icon-file-upload-white-64.png",
    "48": "images/icon-file-upload-white-64.png",
    "128": "images/icon-file-upload-white-64.png"
  },
  "action": {
    "default_icon": {
      "16": "images/icon-file-upload-white-64.png",
      "32": "images/icon-file-upload-white-64.png",
      "48": "images/icon-file-upload-white-64.png",
      "128": "images/icon-file-upload-white-64.png"
    },
    "default_title": "File Viewer"
  },
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": [
        "boolean-string-parser.js",
        "classes/base/base-entity.js",
        "classes/component-manager.js",
        "classes/param-validator.js",
        "classes/record-manager.js",
        "classes/search-manager.js",
        "classes/spinner-manager.js",
        "color-palette.js",
        "content-script.js",
        "scraping-utils.js",
        "country-codes.js",
        "css.js",
        "helper/index.js",
        "helper/modules/build-company-viewer.js",
        "helper/modules/build-container.js",
        "helper/modules/build-loading-spinner.js",
        "helper/modules/build-part.js",
        "helper/modules/build-saved-search-viewer.js",
        "helper/modules/build-viewer-section.js",
        "helper/modules/build-xh-ui.js",
        "helper/modules/run-highlighter.js",
        "helper/modules/update-curation-checkbox-list.js",
        "icons.js",
        "images/icon-add.png",
        "images/icon-delete.png",
        "init/index.js",
        "init/modules/init-advanced-highlighter-html.js",
        "init/modules/init-content-processing.js",
        "message-passing/index.js",
        "message-passing/modules/message-local-storage.js",
        "utils/shared/check/classes/object-checker.js",
        "utils/shared/check/index.js",
        "utils/shared/check/modules/is-empty-arr.js",
        "utils/shared/check/modules/is-empty-obj.js",
        "utils/shared/check/modules/is-json-array.js",
        "utils/shared/manip-arr/index.js",
        "utils/shared/manip-arr/modules/misca.js",
        "utils/shared/manip-file/download-to-files/index.js",
        "utils/shared/manip-file/download-to-files/modules/download-to-local-file.js",
        "utils/shared/manip-file/download-to-files/modules/to-file-format.js",
        "utils/shared/manip-file/file-reader/index.js",
        "utils/shared/manip-file/file-reader/modules/get-content.js",
        "utils/shared/manip-file/file-reader/modules/handle-files.js",
        "utils/shared/manip-json/index.js",
        "utils/shared/manip-json/modules/add-rec-by.js",
        "utils/shared/manip-json/modules/unique-key.js",
        "utils/shared/manip-node/index.js",
        "utils/shared/manip-node/modules/get-leaf-nodes.js",
        "utils/shared/manip-node/modules/get-leaf-value.js",
        "utils/shared/manip-node/modules/get-val-at-node-cascading.js",
        "utils/shared/manip-str/index.js",
        "utils/shared/manip-str/modules/split-to-sentences.js",
        "utils/shared/manip-str/modules/to-html-list.js",
        "utils/shared/manip-str/modules/to-plural-or-singular-noun.js",
        "utils/shared/manip-str/modules/to-regex-pattern-escape.js",
        "utils/shared/manip-str/modules/try-regexp.js",
        "utils/shared/type-of.js",
        "utils/shared/manip-data/modules/encoding-decoding.js",
        "utils/web/action-dom/index.js",
        "utils/web/action-dom/modules/focus-text-area-input.js",
        "utils/web/action-dom/modules/notify-user.js",
        "utils/web/action-dom/modules/show-spinner.js",
        "utils/web/action-dom/modules/show-toast.js",
        "utils/web/action-dom/modules/toggle-always-on.js",
